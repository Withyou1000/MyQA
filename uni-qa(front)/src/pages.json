	"tabBar": {
		"color": "#999999",
		"selectedColor": "#007AFF",
		"backgroundColor": "#FFFFFF",
		"borderStyle": "black",
		"fontSize": "12px",
		"iconWidth": "24px",
		"spacing": "3px",
		"height": "50px",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "问答",
				"iconPath": "/static/images/tab-question.svg",
				"selectedIconPath": "/static/images/tab-question-active.svg"
			},
			{
				"pagePath": "pages/ask/index",
				"text": "提问",
				"iconPath": "/static/images/tab-ask.svg",
				"selectedIconPath": "/static/images/tab-ask-active.svg"
			},
			{
				"pagePath": "pages/message/index",
				"text": "消息",
				"iconPath": "/static/images/tab-message.svg",
				"selectedIconPath": "/static/images/tab-message-active.svg"
			},
			{
				"pagePath": "pages/profile/index",
				"text": "我的",
				"iconPath": "/static/images/tab-profile.svg",
				"selectedIconPath": "/static/images/tab-profile-active.svg"
			}
		]
	},
	
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#F7F7F7"
	}
}
