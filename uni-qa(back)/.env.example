# MongoDB
DBHOST=127.0.0.1
DBPORT=27017
DBNAME=myqa

# JWT
JWT_SECRET=jjcyyds

# HTTP
PORT=3000

# AI 模型网关（OpenAI 兼容接口）
AI_BASE_URL=https://your-gateway.example.com/v1
AI_API_KEY=your_api_key
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=30000

# rag_py 服务地址
RAG_SERVICE_URL=http://127.0.0.1:8001
RAG_SERVICE_TIMEOUT_MS=30000

# 兼容保留：这些配置主要由 rag_py 子项目使用
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
RAG_RERANK_MODEL=BAAI/bge-reranker-base

# Qdrant（主要由 rag_py 使用）
QDRANT_PATH=./.qdrant
QDRANT_COLLECTION_NAME=customer_service_knowledge

# RAG 检索
RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0.3
RAG_RERANK_ENABLED=false
